class Animal
{
    void eat()
    {
        System.out.println("Animal can eat");
    }
}
class Dog extends Animal
{
    void bark()
    {
        System.out.println("Dog can bark");
    }
}
class Cat extends Animal
{
    void meow()
    {
        System.out.println("Cat can meow");
    }
}
public class Main
{
    public static void main(String[]args)
    {
        Dog d = new Dog();
        Cat c= new Cat();
        d.eat();
        d.bark();
        c.eat();
        c.meow();
    }
}
