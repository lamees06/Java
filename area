class Area{
    void area(int s){
        System.out.println("Area of square:"+(s*s));
    }
    void area(int l,int b){
        System.out.println("Area of rectangle:"+(l*b));
    }
    public static void main(String[] args)
    {
            Area a=new Area();
            a.area(5);
            a.area(5,10);
    }
}
